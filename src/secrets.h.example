#pragma once

// WiFi credentials are no longer compiled in — set them at runtime through
// the "CoinDeck-Setup" captive portal that opens on first boot (or whenever
// the saved network is out of range). Lets you switch between home WiFi and
// a phone hotspot without reflashing.

// Cloudflare Worker that serves /github and /usage.
// See tools/coindeck-worker/README.md for deploy steps. No trailing slash.
#define WORKER_BASE_URL "https://coindeck.your-subdomain.workers.dev"
